# ─────────────────────────────────────────────────────────────────────────────
# Railway production environment template for ETHOS.
# Copy these keys into Railway → Service → Variables (do NOT commit real values).
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME=ETHOS
APP_ENV=production
APP_KEY=                         # generate with: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://<your-railway-domain>
APP_TIMEZONE=UTC
LOG_CHANNEL=stack
LOG_LEVEL=warning

# Runtime behaviour (consumed by docker/entrypoint.sh)
RUN_MIGRATIONS=true
GENERATE_SWAGGER=false

# ── Database (MySQL service on Railway) ─────────────────────────────────────
# Railway exposes these as reference variables from the MySQL plugin.
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ── Cache / Queue / Session ─────────────────────────────────────────────────
# NOTE: SESSION_DRIVER=file works out of the box on Railway. Switch to
# 'database' only after adding a sessions migration (php artisan session:table).
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
BROADCAST_DRIVER=log
FILESYSTEM_DISK=local

# ── Security / CORS / Sanctum ───────────────────────────────────────────────
FRONTEND_URL=https://<your-railway-domain>
CORS_ALLOWED_ORIGINS=https://<your-railway-domain>
CORS_SUPPORTS_CREDENTIALS=true
SANCTUM_STATEFUL_DOMAINS=<your-railway-domain>
SESSION_DOMAIN=<your-railway-domain>
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
TRUSTED_PROXIES=*

# ── Mail (configure a real provider before going live) ──────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ── Integrations / keys ─────────────────────────────────────────────────────
IA_API=
IA_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
IA_TIMEOUT=30
IA_DASHBOARD_API=
IA_DASHBOARD_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
IA_DASHBOARD_TIMEOUT=30

GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=
